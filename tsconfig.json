{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "types": ["chrome"]
  },
  "include": ["js/**/*.js"],
  "exclude": ["js/**/*.test.js", "node_modules"]
}

