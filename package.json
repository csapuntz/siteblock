{
  "name": "siteblock",
  "version": "0.3.1",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "format": "biome format --write",
    "format:check": "biome format",
    "lint": "eslint js/ && biome lint",
    "typecheck": "tsc",
    "pack": "zip -r siteblock-$(node -p \"require('./package.json').version\").zip manifest.json html/ js/ --exclude 'js/*.test.js'"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/chrome": "^0.1.38",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
